<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#99000000"
        android:padding="6dp">

        <View
            android:id="@+id/pointer_dot"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@android:drawable/presence_online" />

        <ImageView
            android:id="@+id/btn_gear"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_manage" />

        <ImageView
            android:id="@+id/btn_lock"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_lock_idle_lock" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_macro_trigger"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginTop="12dp"
        android:text="MACRO"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:elevation="8dp" />

    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#DD000000"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/label_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensitivity X: 1.0x"
            android:textColor="#FFFFFF" />

        <SeekBar
            android:id="@+id/seek_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20" />

        <TextView
            android:id="@+id/label_y"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensitivity Y: 1.0x"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <SeekBar
            android:id="@+id/seek_y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20" />
    </LinearLayout>
</LinearLayout>
